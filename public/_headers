/*
  # Only allow resources from your own domain + the CDN sources the app actually uses
  Content-Security-Policy: default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self'; connect-src 'self'; frame-ancestors 'none'
  # Prevent your page from being embedded in iframes (clickjacking)
  X-Frame-Options: DENY
  # Stop browsers from guessing content types
  X-Content-Type-Options: nosniff
  # Don't send your URL as referrer to external sites
  Referrer-Policy: strict-origin-when-cross-origin
  # Restrict powerful browser features (camera, mic, etc.) — none needed for this app
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=()
